{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'ROOT=$(git rev-parse --show-toplevel 2>/dev/null) && python3 \"$ROOT/.claude/hooks/post_test_edit.py\" || exit 0'",
            "timeout": 45000
          }
        ]
      }
    ]
  }
}
