{
  "name": "@verum/sdk",
  "version": "0.1.0",
  "description": "Verum SDK — connect your AI service to The Verum Loop",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./openai": "./dist/openai.js",
    "./anthropic": "./dist/anthropic.js",
    "./auto": "./dist/auto.js"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xzawed/verum"
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/jest": "^29",
    "@types/node": "^25.6.0",
    "jest": "^29",
    "ts-jest": "^29",
    "typescript": "^5.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "moduleNameMapper": {
      "^(.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "commonjs",
            "moduleResolution": "node"
          }
        }
      ]
    },
    "coverageReporters": [
      "text",
      "lcov",
      "json-summary"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ]
  }
}
