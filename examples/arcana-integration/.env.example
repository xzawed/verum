# ── Phase 0: OTLP env-only (zero code changes) ───────────────────────────────
# Set this variable in your service. No code changes required.
# Verum receives OpenTelemetry spans and enables the OBSERVE stage.
OTEL_EXPORTER_OTLP_ENDPOINT=https://verum-production.up.railway.app/otlp

# ── Phase 1: Bidirectional SDK integration ────────────────────────────────────
# Requires `pip install verum` + `import verum.openai` in your entry point.
VERUM_API_URL=https://verum-production.up.railway.app
VERUM_API_KEY=vk_your_api_key_here
VERUM_DEPLOYMENT_ID=dep_your_deployment_id_here

# Your LLM provider
OPENAI_API_KEY=sk-your_openai_key_here
# or
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
