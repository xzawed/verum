# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://verum:verum@localhost:5432/verum

# ── Authentication ────────────────────────────────────────────────────────────
AUTH_SECRET=your_auth_secret_here
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ── LLM providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
OPENAI_API_KEY=sk-your_openai_key_here

# ── Embeddings — Voyage AI (voyage-3.5, 1024-dim) ────────────────────────────
# Used by the retrieve-sdk endpoint and the HARVEST stage for chunk embeddings.
# https://docs.voyageai.com/
VOYAGE_API_KEY=pa-your_voyage_key_here

# ── Security ──────────────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting Railway API tokens at rest.
# 64-char hex string (32 bytes). Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Runtime ───────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── Rate limiting (optional — defaults shown) ─────────────────────────────────
# Per-API-key and per-IP limits for the /api/v1/traces SDK endpoint.
VERUM_TRACE_RATE_LIMIT_PER_KEY=120
VERUM_TRACE_RATE_LIMIT_PER_IP=200

# ── Redis (optional — falls back to in-memory rate limiting if unset) ─────────
REDIS_URL=redis://localhost:6379

# ── Python worker (optional — defaults work for Docker and local dev) ─────────
# Set SKIP_PYTHON_WORKER=1 to disable alembic migrations + worker spawn (e.g. in CI).
SKIP_PYTHON_WORKER=
# Override the working directory for the Python worker (defaults to ../../apps/api from CWD).
PYTHON_WORKER_CWD=
# Override the Python binary (must be one of: python3, python, python3.13, python3.12).
PYTHON_BIN=python3
